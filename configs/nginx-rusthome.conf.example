# Example nginx server block for rusthome (include from http {} or sites-enabled)
#
# Prerequisites:
#   rusthome serve --data-dir /path/to/data --bind 127.0.0.1:8080
#
# Adjust ssl_certificate paths; create htpasswd for auth_basic if needed.

upstream rusthome_ui {
	server 127.0.0.1:8080;
	keepalive 8;
}

server {
	listen 443 ssl http2;
	server_name rusthome.home.arpa;

	ssl_certificate     /etc/ssl/certs/rusthome.crt;
	ssl_certificate_key /etc/ssl/private/rusthome.key;

	# Optional Basic Auth:
	# auth_basic           "rusthome";
	# auth_basic_user_file /etc/nginx/rusthome.htpasswd;

	location / {
		proxy_pass         http://rusthome_ui;
		proxy_http_version 1.1;
		proxy_set_header   Host              $host;
		proxy_set_header   X-Real-IP         $remote_addr;
		proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
		proxy_set_header   X-Forwarded-Proto $scheme;
	}
}
